# Environment variables declared in this file are available at build-time and run-time.
# Don't commit production database credentials to Git

# PostgreSQL Database URL
DATABASE_URL="postgresql://clegaard@localhost:5432/underwater_housings?schema=public"
# Optionally, you can use a different database provider
# DATABASE_URL="file:./dev.db"  # SQLite for development

# Next.js
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="o3lWXGzYsHrELnRhzt1qDUpMSoKZSQPMiyT5lCqnZ/Y="

# ─── Object Storage (S3-compatible) ──────────────────────────────────────────
# Leave NEXT_PUBLIC_STORAGE_BASE_URL empty to serve from /public (default dev).
# Set to the public bucket URL when using MinIO or a production S3 provider.
#
# MinIO local dev (docker-compose):
#   docker compose up -d
#   Then uncomment the four lines below:
#
NEXT_PUBLIC_STORAGE_BASE_URL=http://localhost:9000/underwaterhousings
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=underwaterhousings
S3_REGION=us-east-1
