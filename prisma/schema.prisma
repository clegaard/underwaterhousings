generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Manufacturer {
    id            Int            @id @default(autoincrement())
    name          String         @unique
    slug          String         @unique
    description   String?
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    housingMounts HousingMount[]
    cameras       Camera[]
    housings      Housing[]
    lenses        Lens[]
    ports         Port[]
    logoPath      String?

    @@map("manufacturers")
}

model CameraMount {
    id          Int      @id @default(autoincrement())
    name        String
    slug        String   @unique
    description String?
    cameras     Camera[]
    lens        Lens[]

    @@map("camera_mounts")
}

model HousingMount {
    id             Int          @id @default(autoincrement())
    name           String
    description    String?
    manufacturerId Int
    slug           String       @unique
    manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
    housings       Housing[]
    ports          Port[]
}

model Camera {
    id                       Int            @id @default(autoincrement())
    name                     String
    slug                     String         @unique
    description              String?
    manufacturerId           Int
    cameraMountId            Int?
    priceCurrency            String?        @default("USD")
    priceAmount              Decimal?       @db.Decimal(10, 2)
    productPhotos            String[]
    interchangeableLens      Boolean        @default(true)
    canBeUsedWithoutAHousing Boolean        @default(false)
    exifId                   String?        @unique
    rigReviews               RigReview[]
    cameraMount              CameraMount?   @relation(fields: [cameraMountId], references: [id])
    brand                    Manufacturer   @relation(fields: [manufacturerId], references: [id])
    galleryPhotos            GalleryPhoto[]
    housings                 Housing[]
    lens                     Lens[]

    @@map("cameras")
}

model Housing {
    id                  Int            @id @default(autoincrement())
    name                String
    slug                String         @unique
    description         String?
    priceAmount         Decimal?       @db.Decimal(10, 2)
    priceCurrency       String?        @default("USD")
    depthRating         Int
    material            String?
    manufacturerId      Int
    cameraId            Int
    housingMountId      Int?
    productPhotos       String[]
    interchangeablePort Boolean        @default(true)
    rigReviews          RigReview[]
    galleryPhotos       GalleryPhoto[]
    Camera              Camera         @relation(fields: [cameraId], references: [id])
    housingMount        HousingMount?  @relation(fields: [housingMountId], references: [id])
    manufacturer        Manufacturer   @relation(fields: [manufacturerId], references: [id])

    @@map("housings")
}

model Port {
    id              Int            @id @default(autoincrement())
    name            String
    slug            String         @unique
    description     String?
    manufacturerId  Int
    housingMountId  Int?
    productPhotos   String[]
    priceAmount     Decimal?       @db.Decimal(10, 2)
    priceCurrency   String?        @default("USD")
    isFlatPort      Boolean        @default(false) // True if it's a flat port, false if it's a dome port
    hemisphereWidth Float? // For dome ports, the width of the hemisphere in mm
    rigReviews      RigReview[]
    galleryPhotos   GalleryPhoto[]
    housingMount    HousingMount?  @relation(fields: [housingMountId], references: [id])
    manufacturer    Manufacturer   @relation(fields: [manufacturerId], references: [id])
    lens            Lens[]         @relation("LensToPort")

    @@map("ports")
}

model Lens {
    id                   Int            @id @default(autoincrement())
    name                 String
    slug                 String         @unique
    description          String?
    minimumFocusDistance Float?
    priceAmount          Decimal?       @db.Decimal(10, 2)
    priceCurrency        String?        @default("USD")
    cameraMountId        Int
    cameraId             Int?
    productPhotos        String[]
    manufacturerId       Int
    exifId               String?        @unique
    rigReviews           RigReview[]
    galleryPhotos        GalleryPhoto[]
    camera               Camera?        @relation(fields: [cameraId], references: [id])
    cameraMount          CameraMount    @relation(fields: [cameraMountId], references: [id])
    manufacturer         Manufacturer?  @relation(fields: [manufacturerId], references: [id])
    ports                Port[]         @relation("LensToPort")

    @@map("lenses")
}

model User {
    id             Int            @id @default(autoincrement())
    email          String         @unique
    password       String
    name           String?
    bio            String?
    profilePicture String?
    isSuperuser    Boolean        @default(false)
    isUser         Boolean        @default(true)
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt
    rigReviews     RigReview[]
    galleryPhotos  GalleryPhoto[]

    @@map("users")
}

model GalleryPhoto {
    id           Int       @id @default(autoincrement())
    title        String?
    description  String?
    imagePath    String
    width        Int
    height       Int
    takenAt      DateTime?
    location     String?
    focalLength  Float?
    shutterSpeed String?
    aperture     Float?
    createdAt    DateTime  @default(now())
    cameraId     Int?
    lensId       Int?
    housingId    Int?
    portId       Int?
    userId       Int?
    camera       Camera?   @relation(fields: [cameraId], references: [id])
    housing      Housing?  @relation(fields: [housingId], references: [id])
    lens         Lens?     @relation(fields: [lensId], references: [id])
    port         Port?     @relation(fields: [portId], references: [id])
    user         User?     @relation(fields: [userId], references: [id])

    @@map("gallery_photos")
}

model RigReview {
    id                   Int      @id @default(autoincrement())
    comment              String?
    createdAt            DateTime @default(now())
    updatedAt            DateTime @updatedAt
    ratingOpticalQuality Int
    ratingReliability    Int
    ratingEaseOfUse      Int
    cameraId             Int?
    housingId            Int?
    portId               Int?
    lensId               Int?
    userId               Int
    reviewPhotos         String[]
    camera               Camera?  @relation(fields: [cameraId], references: [id])
    housing              Housing? @relation(fields: [housingId], references: [id])
    lens                 Lens?    @relation(fields: [lensId], references: [id])
    port                 Port?    @relation(fields: [portId], references: [id])
    user                 User     @relation(fields: [userId], references: [id])

    @@map("rig_reviews")
}
