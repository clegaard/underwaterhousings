generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model HousingManufacturer {
    id            String         @id @default(cuid())
    name          String         @unique
    slug          String         @unique
    description   String?
    housings      Housing[]
    ports         Port[]
    extensions    Extension[]
    housingMounts HousingMount[]

    @@map("housing_manufacturers")
}

model CameraManufacturer {
    id        String   @id @default(cuid())
    name      String   @unique
    slug      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    cameras   Camera[]

    @@map("camera_manufacturers")
}

model CameraMount {
    id      String   @id @default(cuid())
    slug    String   @unique
    name    String
    cameras Camera[]
    lens    Lens[]

    @@map("camera_mounts")
}

model HousingMount {
    id                    String              @id @default(cuid())
    name                  String
    description           String?
    ports                 Port[]
    manufacturer          HousingManufacturer @relation(fields: [housingManufacturerId], references: [id])
    housingManufacturerId String
}

model Camera {
    id                   String             @id @default(cuid())
    name                 String
    slug                 String             @unique
    brand                CameraManufacturer @relation(fields: [cameraManufacturerId], references: [id])
    cameraManufacturerId String
    cameraMount          CameraMount?       @relation(fields: [cameraMountId], references: [id])
    cameraMountId        String?
    housings             Housing[]
    lens                 Lens[]

    @@map("cameras")
}

model Housing {
    id                    String               @id @default(cuid())
    model                 String
    name                  String
    slug                  String               @unique
    description           String?
    priceAmount           Decimal?             @db.Decimal(10, 2)
    priceCurrency         String?              @default("USD")
    depthRating           Int
    material              String?
    manufacturer          HousingManufacturer  @relation(fields: [housingManufacturerId], references: [id])
    Camera                Camera?              @relation(fields: [cameraId], references: [id])
    cameraId              String?
    housingManufacturerId String
    portExtensionCombos   PortExtensionCombo[]

    @@map("housings")
}

model Port {
    id                    String               @id @default(cuid())
    manufacturer          HousingManufacturer  @relation(fields: [housingManufacturerId], references: [id])
    housingManufacturerId String
    name                  String
    lens                  Lens?                @relation(fields: [lensId], references: [id])
    lensId                String?
    portExtensionCombos   PortExtensionCombo[]
    housingMount          HousingMount?        @relation(fields: [housingMountId], references: [id])
    housingMountId        String?

    @@map("ports")
}

model Extension {
    id                    String               @id @default(cuid())
    manufacturer          HousingManufacturer  @relation(fields: [housingManufacturerId], references: [id])
    housingManufacturerId String
    name                  String
    portExtensionCombos   PortExtensionCombo[]

    @@map("extensions")
}

model PortExtensionCombo {
    id                String     @id @default(cuid())
    housing           Housing    @relation(fields: [housingId], references: [id])
    housingId         String
    port              Port       @relation(fields: [portId], references: [id])
    portId            String
    extensionRelation Extension? @relation(fields: [extensionId], references: [id])
    extensionId       String?
    lens              Lens?      @relation(fields: [lensId], references: [id])
    lensId            String?

    @@map("port_extension_combos")
}

model Lens {
    id                            String               @id @default(cuid())
    name                          String
    slug                          String               @unique
    cameraMount                   CameraMount?         @relation(fields: [cameraMountId], references: [id])
    cameraMountId                 String?
    camera                        Camera?              @relation(fields: [cameraId], references: [id])
    cameraId                      String?
    compatiblePortExtensionCombos PortExtensionCombo[]
    ports                         Port[]

    @@map("lenses")
}
