generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Manufacturer {
    id               Int             @id @default(autoincrement())
    name             String          @unique
    slug             String          @unique
    description      String?
    createdAt        DateTime        @default(now())
    updatedAt        DateTime        @updatedAt
    housingMounts    HousingMount[]
    cameras          Camera[]
    housings         Housing[]
    lenses           Lens[]
    ports            Port[]
    extensionRings   ExtensionRing[]
    portAdapters     PortAdapter[]
    gears            Gear[]
    logoPath         String?
    logoContainsName Boolean         @default(false)

    @@map("manufacturers")
}

model CameraMount {
    id          Int      @id @default(autoincrement())
    name        String
    slug        String   @unique
    description String?
    cameras     Camera[]
    lens        Lens[]

    @@map("camera_mounts")
}

model HousingMount {
    id             Int             @id @default(autoincrement())
    name           String
    description    String?
    manufacturerId Int
    slug           String          @unique
    innerDiameter  Float? // Inner diameter in mm, used to determine if a lens will fit inside a port
    manufacturer   Manufacturer    @relation(fields: [manufacturerId], references: [id])
    housings       Housing[]
    ports          Port[]
    extensionRings ExtensionRing[]
    inputAdapters  PortAdapter[]   @relation("AdapterInputMount")
    outputAdapters PortAdapter[]   @relation("AdapterOutputMount")
}

model Camera {
    id             Int      @id @default(autoincrement())
    name           String
    slug           String   @unique
    description    String?
    manufacturerId Int
    cameraMountId  Int?
    priceCurrency  String?  @default("USD")
    priceAmount    Decimal? @db.Decimal(10, 2)
    productPhotos  String[]

    productId     String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl    String? // Link to the product page on the manufacturer's website
    exifId        String?        @unique
    cameraSystems CameraSystem[]
    cameraMount   CameraMount?   @relation(fields: [cameraMountId], references: [id])
    brand         Manufacturer   @relation(fields: [manufacturerId], references: [id])
    housings      Housing[]
    lens          Lens[]

    sensorWidth  Float? // optional field for sensor width in mm, used for calculating crop factor
    sensorHeight Float? // optional field for sensor height in mm, used for calculating crop factor
    megapixels   Float? // optional field for megapixels, used for calculating pixel density

    // ================ WATERPROOF CAMERA FIELDS ================
    canBeUsedWithoutAHousing Boolean @default(false) // True if the camera can be used underwater without a housing, false if it always requires a housing
    depthRating              Int? // optional field for maximum depth rating of the camera without a housing

    // ================ FIXED LENS FIELDS ================
    interchangeableLens      Boolean @default(true)
    isZoomLens               Boolean @default(false) // True if it's a zoom lens, false if it's a prime lens
    focalLengthTele          Int? // Focal length at the tele end in mm (prime lenses: sole focal length)
    focalLengthWide          Int? // Focal length at the wide end in mm; null means prime lens
    minimumFocusDistanceTele Float? // Minimum focus distance at the tele end in metres
    minimumFocusDistanceWide Float? // Minimum focus distance at the wide end in metres
    maximumMagnificationTele Float? // Maximum reproduction ratio at tele end (or sole value for prime), e.g. 0.30 for 0.30×
    maximumMagnificationWide Float? // Maximum reproduction ratio at wide end; null for prime lenses

    @@map("cameras")
}

model Housing {
    id          Int     @id @default(autoincrement())
    name        String
    slug        String  @unique
    productId   String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl  String? // Link to the product page on the manufacturer's website
    description String?

    priceAmount   Decimal? @db.Decimal(10, 2)
    priceCurrency String?  @default("USD")

    // Physical
    depthRating Int
    material    String?

    // Photos
    productPhotos String[]

    cameraMountRecession Float? // Distance from the camera body mount to the housing port flange along the optical axis, in mm
    cameraSystems        CameraSystem[]

    // Compatability
    cameras             Camera[] // list of compatible cameras, for most housings this will be a single camera, but some housings are compatible with multiple cameras
    manufacturerId      Int
    housingMountId      Int?
    housingMount        HousingMount? @relation(fields: [housingMountId], references: [id])
    manufacturer        Manufacturer  @relation(fields: [manufacturerId], references: [id])
    interchangeablePort Boolean       @default(true) // whether or not the housing can accept different ports or it comes with a built-in fixed port

    @@map("housings")
}

model Port {
    id                Int            @id @default(autoincrement())
    name              String
    slug              String         @unique
    description       String?
    manufacturerId    Int
    housingMountId    Int?
    productPhotos     String[]
    priceAmount       Decimal?       @db.Decimal(10, 2)
    priceCurrency     String?        @default("USD")
    isFlatPort        Boolean        @default(false) // True if it's a flat port, false if it's a dome port
    hemisphereWidth   Float? // For dome ports, the width of the hemisphere in mm
    depthRating       Int? // Maximum depth rating of the port in meters
    productId         String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl        String? // Link to the product page on the manufacturer's website
    // Optics fields
    portRadius        Float? // Radius of the port opening (circle) in mm — applies to both flat and dome ports
    portDepth         Float? // Distance from the flange to the start of the optical element along the optical axis, in mm
    radiusOfCurvature Float? // Dome ports only: radius of the spherical dome in mm. Must be >= portRadius
    cameraSystems     CameraSystem[]
    housingMount      HousingMount?  @relation(fields: [housingMountId], references: [id])
    manufacturer      Manufacturer   @relation(fields: [manufacturerId], references: [id])
    lens              Lens[]         @relation("LensToPort")

    @@map("ports")
}

model ExtensionRing {
    id             Int            @id @default(autoincrement())
    name           String
    slug           String         @unique
    description    String?
    manufacturerId Int
    housingMountId Int? // The port mount system it fits
    lengthMm       Int? // Length in millimeters
    priceAmount    Decimal?       @db.Decimal(10, 2)
    priceCurrency  String?        @default("USD")
    productPhotos  String[]
    productId      String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl     String? // Link to the product page on the manufacturer's website
    manufacturer   Manufacturer   @relation(fields: [manufacturerId], references: [id])
    housingMount   HousingMount?  @relation(fields: [housingMountId], references: [id])
    cameraSystems  CameraSystem[]

    @@map("extension_rings")
}

model PortAdapter {
    id                   Int            @id @default(autoincrement())
    name                 String
    slug                 String         @unique
    description          String?
    manufacturerId       Int
    inputHousingMountId  Int? // The mount on the housing side
    outputHousingMountId Int? // The mount on the port side
    priceAmount          Decimal?       @db.Decimal(10, 2)
    priceCurrency        String?        @default("USD")
    productPhotos        String[]
    productId            String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl           String? // Link to the product page on the manufacturer's website
    manufacturer         Manufacturer   @relation(fields: [manufacturerId], references: [id])
    inputHousingMount    HousingMount?  @relation("AdapterInputMount", fields: [inputHousingMountId], references: [id])
    outputHousingMount   HousingMount?  @relation("AdapterOutputMount", fields: [outputHousingMountId], references: [id])
    cameraSystems        CameraSystem[]

    @@map("port_adapters")
}

model Lens {
    id Int @id @default(autoincrement())

    // product
    name          String
    slug          String   @unique
    description   String?
    productId     String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl    String? // Link to the product page on the manufacturer's website
    productPhotos String[]
    priceAmount   Decimal? @db.Decimal(10, 2)
    priceCurrency String?  @default("USD")

    // optical specifications
    minimumFocusDistanceTele  Float? // Minimum focus distance at the tele end in metres
    minimumFocusDistanceWide  Float? // Minimum focus distance at the wide end in metres
    isZoomLens                Boolean @default(false) // True if it's a zoom lens, false if it's a prime lens
    focalLengthTele           Int // Focal length at the tele end in mm (prime lenses: sole focal length)
    focalLengthWide           Int? // Focal length at the wide end in mm; null means prime lens
    maximumMagnificationTele  Float? // Maximum reproduction ratio at tele end (or sole value for prime), e.g. 0.30 for 0.30×
    maximumMagnificationWide  Float? // Maximum reproduction ratio at wide end; null for prime lenses
    entrancePupilDistanceTele Float? // Distance from lens flange to entrance pupil at tele end (or sole value for prime) in mm
    entrancePupilDistanceWide Float? // Distance from lens flange to entrance pupil at wide end in mm; null for prime lenses

    // exif
    exifId String? @unique // Optional EXIF identifier for matching photos taken with this lens

    // relations
    cameraMountId  Int
    manufacturerId Int
    cameraId       Int?
    cameraSystems  CameraSystem[]
    camera         Camera?        @relation(fields: [cameraId], references: [id])
    cameraMount    CameraMount    @relation(fields: [cameraMountId], references: [id])
    manufacturer   Manufacturer?  @relation(fields: [manufacturerId], references: [id])
    ports          Port[]         @relation("LensToPort")
    gears          Gear[]         @relation("GearToLens")

    @@map("lenses")
}

model Gear {
    id Int @id @default(autoincrement())

    // product
    name          String
    slug          String   @unique
    productId     String? // Manufacturer product ID / SKU (unique within manufacturer)
    productUrl    String? // Link to the product page on the manufacturer's website
    description   String?
    priceAmount   Decimal? @db.Decimal(10, 2)
    priceCurrency String?  @default("USD")
    productPhotos String[]

    // relations
    manufacturerId Int?
    manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])
    lenses         Lens[]        @relation("GearToLens") // lenses which the gear fit onto

    @@map("gears")
}

model User {
    id                    Int      @id @default(autoincrement())
    email                 String   @unique
    password              String?
    name                  String?
    oauthAvatarUrl        String?
    bio                   String?
    profilePicture        String?
    isSuperuser           Boolean  @default(false)
    isUser                Boolean  @default(true)
    defaultCameraSystemId Int?
    createdAt             DateTime @default(now())
    updatedAt             DateTime @updatedAt
    // Profile settings
    publicEmail           String?
    website               String?
    twitterHandle         String?
    instagramHandle       String?
    linkedinUrl           String?
    // Gallery settings
    allowFullResDownload  Boolean  @default(true)

    // Relations
    reviews         Review[]
    galleryPhotos   GalleryPhoto[]
    cameraSystems   CameraSystem[]
    galleryComments GalleryComment[]
    galleryLikes    GalleryLike[]
    linkedServices  LinkedService[]

    @@map("users")
}

model LinkedService {
    id              Int       @id @default(autoincrement())
    userId          Int
    service         String // "instagram" | "facebook" | "google_photos" | "apple_photos"
    accessToken     String
    refreshToken    String?
    tokenExpiry     DateTime?
    serviceUserId   String?
    serviceUsername String?
    scopes          String?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
    user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, service])
    @@map("linked_services")
}

model PasswordResetToken {
    id           Int      @id @default(autoincrement())
    email        String
    otp          String?
    sessionToken String?
    expiresAt    DateTime
    createdAt    DateTime @default(now())

    @@index([email])
    @@map("password_reset_tokens")
}

model PendingVerification {
    id        Int      @id @default(autoincrement())
    email     String
    name      String?
    password  String
    otp       String
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([email])
    @@map("pending_verifications")
}

model CameraSystem {
    id        Int     @id @default(autoincrement())
    name      String
    imagePath String?
    isActive  Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // relations
    userId         Int // owner of the camera system
    cameraId       Int // required, any system must have a camera
    lensId         Int? // optional, since some cameras have a built-in fixed lens
    housingId      Int? // optional, since some cameras can be used underwater without a housing
    portAdapterId  Int? // optional, since not all systems require a port adapter
    portId         Int? // optional, since some housings have a built-in fixed port or if the system is used without a housing
    user           User            @relation(fields: [userId], references: [id])
    camera         Camera          @relation(fields: [cameraId], references: [id])
    lens           Lens?           @relation(fields: [lensId], references: [id])
    housing        Housing?        @relation(fields: [housingId], references: [id])
    portAdapter    PortAdapter?    @relation(fields: [portAdapterId], references: [id])
    port           Port?           @relation(fields: [portId], references: [id])
    extensionRings ExtensionRing[]
    galleryPhotos  GalleryPhoto[]

    @@map("camera_systems")
}

model GalleryPhoto {
    id        Int       @id @default(autoincrement())
    caption   String?
    imagePath String
    width     Int
    height    Int
    takenAt   DateTime?

    // location fields
    location       String? // Human-readable location name
    locationLat    Float? // Decimal latitude of the photo location
    locationLng    Float? // Decimal longitude of the photo location
    locationRadius Int? // Accuracy radius in metres (like iNaturalist observations)

    // EXIF fields
    focalLength  Float?
    shutterSpeed Decimal? @db.Decimal(10, 7)
    aperture     Float?
    iso          Int?

    createdAt DateTime @default(now())

    // Source tracking for imports (e.g. Instagram). Used to prevent duplicate imports.
    sourceService String? // "instagram" | null
    sourceMediaId String? // platform-specific media ID

    // relations
    cameraSystemId Int
    userId         Int
    cameraSystem   CameraSystem     @relation(fields: [cameraSystemId], references: [id], onDelete: Restrict)
    user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    comments       GalleryComment[]
    likes          GalleryLike[]

    @@unique([userId, sourceService, sourceMediaId])
    @@map("gallery_photos")
}

model GalleryComment {
    id        Int              @id @default(autoincrement())
    body      String
    createdAt DateTime         @default(now())
    photoId   Int
    userId    Int
    parentId  Int?
    photo     GalleryPhoto     @relation(fields: [photoId], references: [id], onDelete: Cascade)
    user      User             @relation(fields: [userId], references: [id])
    parent    GalleryComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
    replies   GalleryComment[] @relation("CommentReplies")

    @@map("gallery_comments")
}

model GalleryLike {
    photoId Int
    userId  Int
    photo   GalleryPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
    user    User         @relation(fields: [userId], references: [id])

    @@id([photoId, userId])
    @@map("gallery_likes")
}

model Review {
    id         Int               @id @default(autoincrement())
    title      String
    body       String            @default("") // TipTap HTML content
    status     String            @default("draft") // draft | published
    userId     Int
    user       User              @relation(fields: [userId], references: [id])
    components ReviewComponent[]
    createdAt  DateTime          @default(now())
    updatedAt  DateTime          @updatedAt

    @@map("reviews")
}

model ReviewComponent {
    id            Int     @id @default(autoincrement())
    reviewId      Int
    componentType String // "camera" | "lens" | "housing" | "port" | "portAdapter" | "extensionRing"
    componentId   Int
    description   String? // short description of this component in context (e.g. "Used for wide angle")
    review        Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

    @@unique([reviewId, componentType, componentId])
    @@map("review_components")
}

