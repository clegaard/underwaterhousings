generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model HousingManufacturer {
    id            Int            @id @default(autoincrement())
    name          String         @unique
    slug          String         @unique
    description   String?
    housings      Housing[]
    ports         Port[]
    housingMounts HousingMount[]

    @@map("housing_manufacturers")
}

model CameraManufacturer {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    slug      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    cameras   Camera[]

    @@map("camera_manufacturers")
}

model CameraMount {
    id      Int      @id @default(autoincrement())
    slug    String   @unique
    name    String
    cameras Camera[]
    lens    Lens[]

    @@map("camera_mounts")
}

model HousingMount {
    id                    Int                 @id @default(autoincrement())
    name                  String
    description           String?
    ports                 Port[]
    housings              Housing[]
    manufacturer          HousingManufacturer @relation(fields: [housingManufacturerId], references: [id])
    housingManufacturerId Int
    slug                  String              @unique
}

model Camera {
    id                   Int                @id @default(autoincrement())
    name                 String
    slug                 String             @unique
    brand                CameraManufacturer @relation(fields: [cameraManufacturerId], references: [id])
    cameraManufacturerId Int
    cameraMount          CameraMount?       @relation(fields: [cameraMountId], references: [id])
    cameraMountId        Int?
    lens                 Lens[]
    housings             Housing[]
    // For simplicity, we can store product photos as an array of strings (URLs or file paths)
    productPhotos        String[]
    interchangeableLens  Boolean            @default(true)
    galleryPhotos        GalleryPhoto[]
    // Identified by EXIF data when users upload photos without explicitly linking to a camera
    exifId               String?            @unique

    @@map("cameras")
}

model Housing {
    id                    Int                 @id @default(autoincrement())
    name                  String
    slug                  String              @unique
    description           String?
    priceAmount           Decimal?            @db.Decimal(10, 2)
    priceCurrency         String?             @default("USD")
    depthRating           Int
    material              String?
    manufacturer          HousingManufacturer @relation(fields: [housingManufacturerId], references: [id])
    housingManufacturerId Int
    Camera                Camera              @relation(fields: [cameraId], references: [id])
    cameraId              Int
    housingMount          HousingMount?       @relation(fields: [housingMountId], references: [id])
    housingMountId        Int?
    productPhotos         String[]
    interchangeablePort   Boolean             @default(true)
    galleryPhotos         GalleryPhoto[]

    @@map("housings")
}

model Port {
    id                    Int                 @id @default(autoincrement())
    slug                  String              @unique
    manufacturer          HousingManufacturer @relation(fields: [housingManufacturerId], references: [id])
    housingManufacturerId Int
    name                  String
    lens                  Lens[]
    housingMount          HousingMount?       @relation(fields: [housingMountId], references: [id])
    housingMountId        Int?
    productPhotos         String[]
    galleryPhotos         GalleryPhoto[]

    @@map("ports")
}

model Lens {
    id            Int            @id @default(autoincrement())
    name          String
    slug          String         @unique
    cameraMount   CameraMount    @relation(fields: [cameraMountId], references: [id])
    cameraMountId Int
    ports         Port[]
    camera        Camera?        @relation(fields: [cameraId], references: [id])
    cameraId      Int?
    productPhotos String[]
    galleryPhotos GalleryPhoto[]
    // Identified by EXIF data when users upload photos without explicitly linking to a lens
    exifId        String?        @unique

    @@map("lenses")
}

// ============================= USERS & AUTH =============================

model User {
    id             Int            @id @default(autoincrement())
    email          String         @unique
    password       String
    name           String?
    bio            String?
    profilePicture String?
    isSuperuser    Boolean        @default(false)
    isUser         Boolean        @default(true)
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt
    galleryPhotos  GalleryPhoto[]

    @@map("users")
}

// ============================= PHOTO GALLERY =============================

model GalleryPhoto {
    id           Int       @id @default(autoincrement())
    title        String?
    description  String?
    imagePath    String
    width        Int
    height       Int
    takenAt      DateTime?
    location     String?
    focalLength  Float?
    shutterSpeed String?
    aperture     Float?
    createdAt    DateTime  @default(now())

    camera    Camera?  @relation(fields: [cameraId], references: [id])
    cameraId  Int?
    lens      Lens?    @relation(fields: [lensId], references: [id])
    lensId    Int?
    housing   Housing? @relation(fields: [housingId], references: [id])
    housingId Int?
    port      Port?    @relation(fields: [portId], references: [id])
    portId    Int?

    user   User? @relation(fields: [userId], references: [id])
    userId Int?

    @@map("gallery_photos")
}
